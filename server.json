{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.3d-era/munin-mcp-server",
  "title": "Munin AI Memory",
  "description": "Pragmatic long-term memory for AI agents with Multi-Project support and GraphRAG. FREE FOREVER.",
  "websiteUrl": "https://munin.kalera.app",
  "repository": {
    "url": "https://github.com/3d-era/munin-for-agents",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@kalera/munin-mcp-server",
      "version": "1.4.1",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MUNIN_API_KEY",
          "description": "Get your free cloud key at https://munin.kalera.app",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "MUNIN_PROJECT_ID",
          "description": "Your target Context Core (Project) ID",
          "isRequired": true
        }
      ]
    }
  ]
}
