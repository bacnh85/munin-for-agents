{
  "name": "kalera-munin",
  "version": "1.0.5",
  "description": "Kalera Munin - Long-Term Memory with GraphRAG Context Cores for Gemini CLI",
  "topics": ["memory", "agent", "kalera", "context", "mcp", "gemini-cli-extension"],
  "permissions": {
    "env": [
      "MUNIN_PROJECT",
      "MUNIN_API_KEY"
    ]
  },
  "settings": [
    {
      "name": "API Key",
      "description": "Munin API Key for authentication.",
      "envVar": "MUNIN_API_KEY"
    },
    {
      "name": "Project ID",
      "description": "Default Context Core (Project) ID for Munin. (Optional)",
      "envVar": "MUNIN_PROJECT"
    }
  ],
  "mcpServers": {
    "munin-mcp": {
      "command": "npx",
      "args": ["-y", "@kalera/munin-gemini@latest", "mcp", "gemini-cli-extension"]
    }
  }
}